---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      body {
        margin: 0;
        color: #172033;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f7f1e8;
      }

      main {
        width: min(72rem, calc(100% - 2rem));
        margin: 0 auto;
        padding: 4rem 0;
      }

      a {
        color: #1c5fb8;
      }

      .callout,
      .feature-card,
      .code-block {
        border: 1px solid #ded2c0;
        border-radius: 1rem;
        background: #fffaf2;
        padding: 1rem;
      }

      .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
        gap: 1rem;
      }

      .badge {
        display: inline-block;
        border-radius: 999px;
        padding: 0.1rem 0.45rem;
        background: #172033;
        color: white;
        font-size: 0.8em;
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
