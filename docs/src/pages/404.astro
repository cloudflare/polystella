---
import Header from "../components/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" description="The requested PolyStella docs page could not be found." noindex>
  <div class="flex min-h-screen flex-col">
    <Header showSidebar={false} />
    <main id="main-content" class="mx-auto flex w-full max-w-2xl flex-1 flex-col justify-center px-6 py-24">
      <p class="font-mono text-sm font-medium uppercase tracking-[0.16em] text-primary">404</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-foreground">Page not found</h1>
      <p class="mt-4 text-muted-foreground">
        This docs page may have moved or may not exist yet.
      </p>
      <a
        href="/"
        class="mt-8 w-fit rounded-lg bg-primary px-4 py-2.5 text-sm font-medium text-primary-foreground no-underline transition-colors hover:bg-primary-hover"
      >
        Back to the docs
      </a>
    </main>
  </div>
</BaseLayout>
